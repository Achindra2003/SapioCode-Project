# ── AI Backend environment ──
# Copy this file to .env and fill in the values.

# LLM (Groq)
GROQ_API_KEY=your_groq_api_key
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_PRIMARY_MODEL=moonshotai/kimi-k2-instruct
GROQ_FALLBACK_MODEL=llama-3.3-70b-versatile

# Service
PORT=8003
LOG_LEVEL=info

# Thresholds
FRUSTRATION_HIGH=0.7
FRUSTRATION_MED=0.4
MASTERY_HIGH=0.7
VIVA_PASS_THRESHOLD=0.7
VIVA_WEAK_THRESHOLD=0.4
VIVA_MIN_QUESTIONS=2

# Security
BLOCKED_IMPORTS=os,sys,subprocess,socket,shutil,ctypes,importlib
